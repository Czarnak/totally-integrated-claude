{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__tia-portal__.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}\\hooks\\tia-write-guard.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "mcp_tia-portal_.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${extensionPath}${/}hooks${/}tia-write-guard.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
